{
  "version": 2,
  "builds": [
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/disabled.html",
      "permanent": false
    },
    {
      "source": "/index.html",
      "destination": "/disabled.html",
      "permanent": false
    },
    {
      "source": "/work.html",
      "destination": "/disabled.html",
      "permanent": false
    },
    {
      "source": "/author.html",
      "destination": "/disabled.html",
      "permanent": false
    },
    {
      "source": "/about.html",
      "destination": "/disabled.html",
      "permanent": false
    },
    {
      "source": "/pages/:path*",
      "destination": "/disabled.html",
      "permanent": false
    }
  ]
}

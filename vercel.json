{
  "version": 2,
  "builds": [
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/css|assets/images|favicon\\.ico|apple-touch-icon\\.png|site\\.webmanifest|site-config\\.json|disabled\\.html).*)",
      "destination": "/disabled.html"
    }
  ]
}
